# PalworldStatus — Environment Variables
# Copy this file to .env and fill in your values.
# In production (Unraid Docker), set these as container environment variables.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Steam 64-bit ID. This account gets full admin access.
# Find yours at: https://steamid.io
ADMIN_STEAM_ID=76561198000000000

# Steam Web API key for resolving player display names.
# Get one at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Public base URL of this app — used for the Steam OpenID callback.
# Must be reachable from the internet for Steam login to work.
# Include the protocol, no trailing slash.
STEAM_REALM=https://palworld.yourdomain.com

# Hostname shown to users on server connection info cards.
# Can be a domain or an IP address.
PUBLIC_HOST=palworld.yourdomain.com

# Random secret for signing session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Optional ──────────────────────────────────────────────────────────────────

# HTTP port to listen on. Default: 3000
# PORT=3000

# Path for the SQLite database file. Default: /app/data/palworld-status.db
# On Unraid, mount /mnt/user/appdata/palworld-status to /app/data
# DB_PATH=/app/data/palworld-status.db

# Path for the location history database (kept separate so it survives DB resets).
# Default: /app/data/palworld-location.db
# LOCATION_DB_PATH=/app/data/palworld-location.db
